rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // File attachments disimpan di path: classes/{classId}/materials/{materialId}/{filename}
    match /classes/{classId}/materials/{materialId}/{allPaths=**} {
      // Semua user yang login bisa download/lihat file.
      allow read: if request.auth != null;
      // Semua user yang login bisa upload file (max 25MB per file).
      allow write: if request.auth != null
                   && request.resource.size < 25 * 1024 * 1024;
    }

    // Badge icons (v1.4.0) disimpan di path: badges/{badgeId}.png
    // Public read — supaya Flutter Image.network bisa load tanpa auth header.
    // Write hanya via Firebase Console / admin SDK (deny semua client write).
    match /badges/{badgeFile} {
      allow read: if true;
      allow write: if false;
    }

    // Profile photos di path: users/{uid}/profile.{ext}
    // Public read — supaya display di profile/leaderboard tanpa auth header.
    // Write hanya owner sendiri (max 5MB).
    match /users/{uid}/{file} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 5 * 1024 * 1024;
    }
  }
}
